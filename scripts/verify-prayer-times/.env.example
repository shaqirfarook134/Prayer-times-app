# Copy to .env (never commit .env) and fill in:

# Anthropic API key — https://platform.claude.com -> API keys
ANTHROPIC_API_KEY=sk-ant-...

# Model used to read the websites (haiku = cheapest, ~1-2c/day for 40 sites)
ANTHROPIC_MODEL=claude-haiku-4-5

# Gmail app password for sending the report.
# Create at https://myaccount.google.com/apppasswords (requires 2FA enabled).
GMAIL_USER=shaqir134@gmail.com
GMAIL_APP_PASSWORD=

# Where the report goes (defaults to GMAIL_USER)
REPORT_TO=shaqir134@gmail.com
