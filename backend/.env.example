# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/prayer_times_db?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=prayer_times_db

# Server Configuration
PORT=8080
GIN_MODE=release
ENVIRONMENT=production

# Firebase Cloud Messaging (Android)
FCM_SERVER_KEY=your_fcm_server_key_here

# Apple Push Notification Service (iOS)
APNS_AUTH_KEY_PATH=/path/to/AuthKey_XXXXX.p8
APNS_KEY_ID=your_key_id
APNS_TEAM_ID=your_team_id
APNS_TOPIC=com.yourapp.prayertimes
APNS_PRODUCTION=true

# Scraper Configuration
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; PrayerTimesBot/1.0)
SCRAPER_TIMEOUT_SECONDS=10
SCRAPER_MAX_RETRIES=3

# Timezone
DEFAULT_TIMEZONE=Australia/Melbourne

# Logging
LOG_LEVEL=info

# Alerting (email notifications for scrape failures and missing prayer times)
ALERT_EMAIL_FROM=your-gmail@gmail.com
ALERT_EMAIL_TO=your-personal-email@gmail.com
ALERT_EMAIL_PASSWORD=your-gmail-app-password
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
